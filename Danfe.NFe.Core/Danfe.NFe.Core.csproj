<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.0;net8.0</TargetFrameworks>
    <LangVersion>latest</LangVersion>

    <!-- Identidade do pacote -->
    <PackageId>Danfe.NFe.Core</PackageId>
    <Version>2.0.1</Version>
    <AssemblyVersion>2.0.1.0</AssemblyVersion>
    <FileVersion>2.0.1.0</FileVersion>

    <!-- Metadata -->
    <Authors>Bruno Moreno (bsmoreno2910); Alexandre Laranjeiras (original); SilverCard (DanfeSharp)</Authors>
    <Company>Bruno Moreno</Company>
    <Copyright>Copyright © 2026 Bruno Moreno</Copyright>
    <NeutralLanguage>pt-BR</NeutralLanguage>
    <Description>Gerador de DANFE NFe modelo 55 em PDF. Refatorado para PdfSharpCore, compatível com .NET Standard 2.0 e .NET 8. Fork/refactor de Zion.NFe.Danfe (Laranjeiras) / DanfeSharp (SilverCard).</Description>
    <PackageTags>danfe;nfe;nota-fiscal-eletronica;pdf;pdfsharpcore;brasil;fiscal</PackageTags>
    <PackageReleaseNotes>v2.0.1 - Correção do canhoto em landscape (margem esquerda vazia): rotação agora usa XGraphics.RotateAtTransform com pivot (X+W/2, Y+W/2) e ângulo -90, compatível com o sistema Y-down do PdfSharpCore. Canhotos rotacionados voltaram a aparecer na lateral esquerda do DANFE em modo paisagem.</PackageReleaseNotes>

    <!-- Links -->
    <PackageProjectUrl>https://github.com/bsmoreno2910/Danfe.NFe.Core</PackageProjectUrl>
    <RepositoryUrl>https://github.com/bsmoreno2910/Danfe.NFe.Core</RepositoryUrl>
    <RepositoryType>git</RepositoryType>

    <!-- Licença -->
    <PackageLicenseExpression>MIT</PackageLicenseExpression>

    <!-- README embarcado (aparece na página do pacote no nuget.org) -->
    <PackageReadmeFile>README.md</PackageReadmeFile>

    <!-- Build -->
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>

    <!-- Symbols para debug dos consumidores (snupkg = NuGet.org padrão) -->
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>

    <OutputType>Library</OutputType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="PdfSharpCore" Version="1.3.65" />
  </ItemGroup>

  <ItemGroup>
    <!-- README do repo é empacotado na raiz do .nupkg -->
    <None Include="..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
